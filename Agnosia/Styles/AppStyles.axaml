<Styles xmlns="https://github.com/avaloniaui"
        xmlns:automation="using:Avalonia.Automation">
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
    <Style Selector="UserControl">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
    <Style Selector="UserControl.overlay-view">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <StyleInclude Source="avares://Agnosia/Styles/AppTextStyles.axaml" />
    <Style Selector="ToggleButton.app-dialog-section-toggle">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ToggleButton.app-dialog-section-toggle:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.app-dialog-section-toggle:checked">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.app-dialog-section-toggle:pressed">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="PathIcon.section-icon">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="PathIcon.section-icon.centered">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="PathIcon.button-icon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="PathIcon.action-icon">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="PathIcon.nav-icon">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Image.app-icon">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stretch" Value="Uniform" />
    </Style>
    <Style Selector="Image.app-icon.dialog">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
    </Style>
    <Style Selector="Border.surface-card">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="StackPanel.content-root">
        <Setter Property="MaxWidth" Value="900" />
        <Setter Property="Margin" Value="18,12,18,16" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Spacing" Value="12" />
    </Style>
    <Style Selector="Grid.content-root">
        <Setter Property="MaxWidth" Value="900" />
        <Setter Property="Margin" Value="18,12,18,16" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="UniformGrid.tile-grid">
        <Setter Property="Columns" Value="2" />
    </Style>
    <Style Selector="Border.surface-card:pointerover">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Border.surface-card.hero">
        <Setter Property="Background" Value="{StaticResource AppChromeBrush}" />
    </Style>
    <Style Selector="Border.surface-card.compact">
        <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.tutorial-step-icon">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
    </Style>
    <Style Selector="Border.tutorial-step-icon PathIcon">
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Border.overlay-panel">
        <Setter Property="MaxWidth" Value="860" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.log-panel">
        <Setter Property="Margin" Value="18,0,18,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.app-control-dialog">
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MaxWidth" Value="380" />
        <Setter Property="MaxHeight" Value="640" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.module-dialog">
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MaxWidth" Value="620" />
        <Setter Property="MaxHeight" Value="720" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Grid.overlay-root">
        <Setter Property="Margin" Value="18" />
    </Style>
    <Style Selector="Border.icon-tile">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.icon-tile.large">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="46" />
    </Style>
    <Style Selector="Border.app-icon-frame">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.app-icon-frame.dialog">
        <Setter Property="Width" Value="54" />
        <Setter Property="Height" Value="54" />
    </Style>
    <Style Selector="Border.permission-risk-badge">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{StaticResource AppRiskSafeBrush}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="Border.permission-risk-badge.safe">
        <Setter Property="Background" Value="{StaticResource AppRiskSafeBrush}" />
    </Style>
    <Style Selector="Border.permission-risk-badge.dangerous">
        <Setter Property="Background" Value="{StaticResource AppRiskDangerousBrush}" />
    </Style>
    <Style Selector="Border.permission-risk-badge.critical">
        <Setter Property="Background" Value="{StaticResource AppRiskCriticalBrush}" />
    </Style>
    <Style Selector="Border.list-card">
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.list-card:pointerover">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Border.surface-card.list-card:pointerover">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Button.app-card-button:pointerover Border.surface-card.list-card">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Button.app-card-button:pressed Border.surface-card.list-card">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Border.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource AppBorderSoftBrush}" />
    </Style>
    <Style Selector="Border.metric-card">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.metric-card.warning">
        <Setter Property="BorderBrush" Value="{StaticResource AppRiskDangerousBrush}" />
    </Style>
    <Style Selector="Border.module-status-chip">
        <Setter Property="Margin" Value="0,4,8,4" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.module-status-chip.enabled">
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
    </Style>
    <Style Selector="Border.module-status-indicator">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Background" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Border.module-status-indicator.enabled">
        <Setter Property="Background" Value="{StaticResource AppBorderBrush}" />
    </Style>
    <Style Selector="Border.module-status-dot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.bottom-nav">
        <Setter Property="Background" Value="{StaticResource AppChromeBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="12,0,12,8" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Border.tag-chip">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="9,5" />
    </Style>
    <Style Selector="Border.tag-chip.dense">
        <Setter Property="Padding" Value="7,4" />
    </Style>
    <Style Selector="Border.tag-chip.accent">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
    </Style>
    <Style Selector="Border.permission-icon">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.permission-icon PathIcon">
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
    </Style>
    <Style Selector="Border.permission-icon.granted">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
    </Style>
    <Style Selector="Border.permission-icon.granted PathIcon">
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="ProgressBar.operation-progress">
        <Setter Property="Height" Value="3" />
        <Setter Property="Background" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="ItemsControl.log-list">
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="Border.log-row">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="TextBlock.log-entry">
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource AppButtonSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource AppButtonSecondaryHoverBrush}" />
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppOnAccentBrush}" />
    </Style>
    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Button.primary:pressed">
        <Setter Property="Background" Value="{StaticResource AppAccentPressedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentPressedBrush}" />
    </Style>
    <Style Selector="Button.nav">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="50" />
        <Setter Property="Height" Value="58" />
        <Setter Property="Transitions">
            <Transitions />
        </Setter>
    </Style>
    <Style Selector="Button.nav:pointerover">
        <Setter Property="Background" Value="{StaticResource AppButtonSecondaryHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppButtonSecondaryHoverBrush}" />
    </Style>
    <Style Selector="Button.nav:pressed">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Button.nav.active">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
    </Style>
    <Style Selector="Button.nav.active:pointerover">
        <Setter Property="Background" Value="{StaticResource AppButtonSecondaryHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppButtonSecondaryHoverBrush}" />
    </Style>
    <Style Selector="Button.nav.active:pressed">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Button.segment-chip">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.segment-chip.profile-segment">
        <Setter Property="MinHeight" Value="52" />
    </Style>
    <Style Selector="Button.segment-chip.selected">
        <Setter Property="Background" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppAccentMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="Button.icon-button">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.compact-action">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.app-dialog-action">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="48" />
    </Style>
    <Style Selector="Button.app-dialog-close">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="MinHeight" Value="38" />
    </Style>
    <Style Selector="Button.app-title-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>
    <Style Selector="Button.app-title-button:pointerover">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.app-title-button:pressed">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.app-card-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>
    <Style Selector="Button.app-card-button:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.app-card-button:pressed">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="SelectionBrush" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="MinHeight" Value="42" />
    </Style>
    <Style Selector="ListBox.apps-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="ItemsControl.apps-list">
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="ListBox.apps-list ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Transitions">
            <Transitions />
        </Setter>
    </Style>
    <Style Selector="ListBox.apps-list ListBoxItem:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.apps-list ListBoxItem:selected">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.apps-list ListBoxItem:selected:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="automation:AutomationProperties.AccessibilityView" Value="Raw" />
    </Style>
</Styles>
