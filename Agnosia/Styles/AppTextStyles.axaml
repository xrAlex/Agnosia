<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.page-caption">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.header-status">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxLines" Value="2" />
    </Style>
    <Style Selector="TextBlock.header-status.error">
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
    </Style>
    <Style Selector="TextBlock.group-title">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
    </Style>
    <Style Selector="TextBlock.group-title.feature-title">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.section-title.compact">
        <Setter Property="FontSize" Value="17" />
    </Style>
    <Style Selector="TextBlock.section-title.hero-title">
        <Setter Property="FontSize" Value="24" />
    </Style>
    <Style Selector="TextBlock.button-label">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.nav-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.app-title">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="TextBlock.app-monogram">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppOnAccentBrush}" />
    </Style>
    <Style Selector="TextBlock.app-monogram.dialog">
        <Setter Property="FontSize" Value="22" />
    </Style>
    <Style Selector="TextBlock.permission-risk-mark">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AppOnAccentBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.app-control-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="TextBlock.app-dialog-setting-title">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.app-dialog-setting-caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.app-dialog-permission-risk-list">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>
    <Style Selector="TextBlock.package-name">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.app-version">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>
    <Style Selector="TextBlock.metric-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.metric-value">
        <Setter Property="FontSize" Value="27" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.metric-support">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.module-status-title">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="128" />
    </Style>
    <Style Selector="TextBlock.tag-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
</Styles>
