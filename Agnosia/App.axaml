<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Agnosia.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Agnosia/Styles/ThemeResources.axaml" />
        <ResourceInclude Source="avares://Agnosia/Styles/Localization.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Dark"
                               Accent="#FF253A"
                               RegionColor="#08090B" />
        <ColorPaletteResources x:Key="Light"
                               Accent="#176BCA"
                               RegionColor="#F6F7F9" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <StyleInclude Source="avares://Agnosia/Styles/AppStyles.axaml" />
  </Application.Styles>
</Application>
