<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Agnosia.ViewModels"
             mc:Ignorable="d"
             x:Class="Agnosia.Views.ModuleDetailsOverlayView"
             x:DataType="vm:DashboardWorkspaceViewModel"
             Classes="overlay-view"
             IsVisible="{Binding IsModuleDetailsOpen}">
    <Design.DataContext>
        <vm:DashboardWorkspaceViewModel />
    </Design.DataContext>

    <Border Background="{StaticResource AppOverlayScrimBrush}">
        <Grid Classes="overlay-root">
            <ContentControl Content="{Binding SelectedModule}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                <ContentControl.DataTemplates>
                    <DataTemplate x:DataType="vm:AgnosiaModuleViewModel">
                        <Border Classes="surface-card module-dialog">
                            <Grid RowDefinitions="Auto,Auto,*,Auto"
                                  RowSpacing="14">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Border Classes="icon-tile large">
                                        <PathIcon Classes="section-icon centered"
                                                  Data="{StaticResource IconModulesGeometry}" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                MinWidth="0"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <TextBlock Classes="section-title"
                                                   Text="{Binding Title}" />
                                        <WrapPanel Orientation="Horizontal"
                                                   IsVisible="{Binding IsStatusTagVisible}">
                                            <Border Classes="tag-chip dense"
                                                    Margin="0,0,8,6">
                                                <TextBlock Classes="tag-label"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Classes="icon-button"
                                            ToolTip.Tip="Закрыть"
                                            Command="{Binding CloseCommand}">
                                        <PathIcon Classes="action-icon"
                                                  Data="{StaticResource IconCloseGeometry}" />
                                    </Button>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Classes="page-caption"
                                               Text="{Binding FullDescription}" />
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <StackPanel MinWidth="0"
                                                Spacing="3">
                                        <TextBlock Classes="app-dialog-setting-title"
                                                   Text="Включить модуль" />
                                        <TextBlock Classes="app-dialog-setting-caption"
                                                   Text="Активация доступна после выполнения требований" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                  IsEnabled="{Binding CanToggle}"
                                                  Command="{Binding ToggleEnabledCommand}" />
                                </Grid>

                                <ScrollViewer Grid.Row="2"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="12">
                                        <Border Classes="divider" />

                                        <StackPanel IsVisible="{Binding IsVpnGuard}"
                                                    Spacing="12">
                                            <TextBlock Classes="group-title"
                                                       Text="Настройки VPN Guard" />

                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <Border Classes="icon-tile">
                                                    <PathIcon Classes="section-icon centered"
                                                              Data="{StaticResource IconVpnOffGeometry}" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            MinWidth="0"
                                                            Spacing="4">
                                                    <TextBlock Classes="section-title compact"
                                                               Text="VPN клиент" />
                                                    <TextBlock Classes="page-caption"
                                                               Text="Команда запуска отправится выбранному клиенту" />
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding VpnAfterFreezeClientOptions}"
                                                          HorizontalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:VpnAutomationClientOptionViewModel">
                                                        <Button MinWidth="100"
                                                                Margin="5"
                                                                Classes="segment-chip"
                                                                Classes.selected="{Binding IsSelected}"
                                                                Command="{Binding SelectCommand}">
                                                            <TextBlock Classes="button-label"
                                                                       Text="{Binding DisplayName}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Classes="tag-chip accent"
                                                    IsVisible="{Binding IsToggleOnlyVpnAfterFreezeWarningVisible}">
                                                <TextBlock Classes="page-caption"
                                                           Text="Выбранный клиент поддерживает только toggle-команду: если VPN уже включен, она может выключить подключение." />
                                            </Border>

                                            <StackPanel IsVisible="{Binding IsTunguskaAutomationTokenVisible}"
                                                        Spacing="6">
                                                <TextBlock Classes="page-caption"
                                                           Text="Токен Tunguska Automation" />
                                                <TextBox PlaceholderText="automation_token"
                                                         PasswordChar="*"
                                                         Text="{Binding TunguskaAutomationToken}" />
                                            </StackPanel>

                                            <Border Classes="divider" />
                                        </StackPanel>

                                        <StackPanel IsVisible="{Binding HasRequirements}"
                                                    Spacing="12">
                                            <TextBlock Classes="group-title"
                                                       Text="Требования" />

                                            <ItemsControl ItemsSource="{Binding Requirements}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Vertical" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:AgnosiaModuleRequirementViewModel">
                                                        <Border Classes="surface-card compact list-card">
                                                            <Grid ColumnDefinitions="Auto,*"
                                                                  RowDefinitions="Auto,Auto,Auto"
                                                                  ColumnSpacing="12"
                                                                  RowSpacing="8">
                                                                <Border Classes="icon-tile permission-icon"
                                                                        Classes.granted="{Binding IsSatisfied}">
                                                                    <PathIcon Classes="section-icon centered"
                                                                              Data="{StaticResource IconCheckGeometry}" />
                                                                </Border>

                                                                <StackPanel Grid.Column="1"
                                                                            MinWidth="0"
                                                                            Spacing="4">
                                                                    <TextBlock Classes="section-title compact"
                                                                               Text="{Binding Title}" />
                                                                    <Border Classes="tag-chip dense"
                                                                            HorizontalAlignment="Left">
                                                                        <TextBlock Classes="tag-label"
                                                                                   Text="{Binding StatusLabel}" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <TextBlock Grid.Row="1"
                                                                           Grid.ColumnSpan="2"
                                                                           Classes="page-caption"
                                                                           Text="{Binding Description}" />

                                                                <Button Grid.Row="2"
                                                                        Grid.ColumnSpan="2"
                                                                        Classes="compact-action"
                                                                        HorizontalAlignment="Left"
                                                                        Command="{Binding RequestCommand}"
                                                                        IsVisible="{Binding CanRequest}">
                                                                    <TextBlock Classes="button-label"
                                                                               Text="{Binding ActionLabel}" />
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <WrapPanel Grid.Row="3"
                                           Orientation="Horizontal">
                                    <Button Classes="primary"
                                            Margin="0,0,10,0"
                                            IsVisible="{Binding IsFileShuttle}"
                                            IsEnabled="{Binding CanOpenDocumentsUi}"
                                            Command="{Binding OpenDocumentsUiCommand}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <PathIcon Classes="button-icon"
                                                      Data="{StaticResource IconFilesGeometry}" />
                                            <TextBlock Classes="button-label"
                                                       Text="Открыть Files" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>
