<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Agnosia.ViewModels"
             xmlns:viewModels="clr-namespace:Agnosia.ViewModels"
             mc:Ignorable="d"
             x:Class="Agnosia.Views.SettingsSectionView"
             x:DataType="vm:DashboardWorkspaceViewModel">
    <Design.DataContext>
        <vm:DashboardWorkspaceViewModel />
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Classes="content-root">
            <TextBlock Classes="page-title"
                       Text="Настройки" />

            <StackPanel IsVisible="{Binding IsDashboardVisible}"
                        Spacing="12">

                <TextBlock Classes="group-title"
                           Text="Базовые настройки" />

                <Border Classes="surface-card compact">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="icon-tile">
                            <PathIcon Classes="section-icon centered"
                                      Data="{StaticResource IconCheckGeometry}" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    MinWidth="0"
                                    Spacing="4">
                            <TextBlock Classes="section-title compact"
                                       Text="Разрешения" />
                            <TextBlock Classes="page-caption"
                                       Text="Выдача разрешений для корректной работы приложения" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="icon-button"
                                ToolTip.Tip="Открыть разрешения"
                                VerticalAlignment="Center"
                                Command="{Binding OpenPermissionsCommand}">
                            <PathIcon Classes="action-icon"
                                      Data="{StaticResource IconCheckGeometry}" />
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Classes="group-title"
                           Text="Тема" />

                <Border Classes="surface-card compact">
                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="14"
                          RowSpacing="12">
                        <Border Classes="icon-tile">
                            <PathIcon Classes="section-icon centered"
                                      Data="{StaticResource IconSettingsGeometry}" />
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1"
                                    MinWidth="0"
                                    Spacing="4">
                            <TextBlock Classes="section-title compact"
                                       Text="Оформление" />
                            <TextBlock Classes="page-caption"
                                       Text="Выберите палитру интерфейса" />
                        </StackPanel>
                        <Grid Grid.Row="1"
                              Grid.ColumnSpan="2" Grid.Column="0"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Classes="segment-chip"
                                    Classes.selected="{Binding IsAgnosiaThemeSelected}"
                                    Command="{Binding SelectAgnosiaThemeCommand}">
                                <TextBlock Classes="button-label"
                                           Text="Красная" />
                            </Button>
                            <Button Grid.Column="1"
                                    Classes="segment-chip"
                                    Classes.selected="{Binding IsDarkThemeSelected}"
                                    Command="{Binding SelectDarkThemeCommand}">
                                <TextBlock Classes="button-label"
                                           Text="Темная" />
                            </Button>
                            <Button Grid.Column="2"
                                    Classes="segment-chip"
                                    Classes.selected="{Binding IsLightThemeSelected}"
                                    Command="{Binding SelectLightThemeCommand}">
                                <TextBlock Classes="button-label"
                                           Text="Светлая" />
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Classes="group-title"
                           Text="Поведение" />

                <Border Classes="surface-card compact">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconAppsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="4">
                                <TextBlock Classes="section-title compact"
                                           Text="Показывать все пакеты" />
                                <TextBlock Classes="page-caption"
                                           Text="Отображать в библиотеке системные и служебные приложения вместе с обычными пакетами" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ShowAllApps}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconLogGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="4">
                                <TextBlock Classes="section-title compact"
                                           Text="Включить логирование" />
                                <TextBlock Classes="page-caption"
                                           Text="Писать отладочные сообщения работы приложения в буфер логирования" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding LoggingEnabled}" />
                        </Grid>

                    </StackPanel>
                </Border>

                <TextBlock Classes="app-version"
                           Text="{Binding AppVersion, StringFormat='Версия {0}'}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
