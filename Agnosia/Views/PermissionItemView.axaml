<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Agnosia.ViewModels"
             x:Class="Agnosia.Views.PermissionItemView"
             x:DataType="vm:PermissionItemViewModel">
    <Border Classes="surface-card compact list-card">
        <Grid ColumnDefinitions="Auto,*"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="12"
              RowSpacing="10">
            <Border Classes="icon-tile permission-icon"
                    Classes.granted="{Binding IsGranted}">
                <PathIcon Classes="section-icon centered"
                          Data="{StaticResource IconCheckGeometry}" />
            </Border>

            <StackPanel Grid.Row="0" Grid.Column="1"
                        MinWidth="0"
                        Spacing="6">
                <TextBlock Classes="section-title compact"
                           Text="{Binding Title}" />
                <WrapPanel Orientation="Horizontal">
                    <Border Classes="tag-chip dense"
                            Margin="0,0,8,6">
                        <TextBlock Classes="tag-label"
                                   Text="{Binding ProfileLabel}" />
                    </Border>
                    <Border Classes="tag-chip dense"
                            Margin="0,0,8,6">
                        <TextBlock Classes="tag-label"
                                   Text="{Binding StatusLabel, Converter={StaticResource LocalizationConverter}, ConverterParameter='String.Permission.'}" />
                    </Border>
                </WrapPanel>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2" Grid.Column="0"
                       Classes="page-caption"
                       Text="{Binding Description}" />

            <Button Grid.Row="2"
                    Grid.ColumnSpan="2" Grid.Column="0"
                    Classes="compact-action"
                    HorizontalAlignment="Left"
                    Command="{Binding RequestCommand}"
                    IsVisible="{Binding CanRequest}">
                <TextBlock Classes="button-label"
                           Text="{Binding RequestLabel}" />
            </Button>
        </Grid>
    </Border>
</UserControl>