<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Agnosia.Controls"
             xmlns:vm="using:Agnosia.ViewModels"
             xmlns:views="using:Agnosia.Views"
             mc:Ignorable="d"
             x:Class="Agnosia.Views.OnboardingOverlayView"
             x:DataType="vm:DashboardWorkspaceViewModel"
             Classes="overlay-view"
             IsVisible="{Binding IsOnboardingVisible}">
    <Design.DataContext>
        <vm:DashboardWorkspaceViewModel />
    </Design.DataContext>

    <Grid Background="{StaticResource AppBackgroundBrush}"
          RowDefinitions="*,Auto">
        <Grid Grid.RowSpan="2"
              IsHitTestVisible="False"
              ClipToBounds="True">
            <controls:PlexusBackground LineBrush="{StaticResource AppPlexusLineBrush}"
                                       NodeBrush="{StaticResource AppPlexusNodeBrush}"
                                       GlowBrush="{StaticResource AppPlexusGlowBrush}"
                                       IsVisible="{Binding IsOnboardingVisible}" />
        </Grid>

        <ProgressBar Grid.Row="0"
                     Classes="operation-progress"
                     VerticalAlignment="Top"
                     IsHitTestVisible="False"
                     IsVisible="{Binding IsOperationActive}"
                     IsIndeterminate="True" />

        <ScrollViewer Grid.Row="0"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Classes="content-root">
                <StackPanel IsVisible="{Binding IsOnboardingWelcomeStep}"
                            Spacing="16">
                    <Border Padding="8,10,8,8"
                            Background="Transparent">
                        <Grid ColumnDefinitions="*">
                            <StackPanel MinWidth="0"
                                        Spacing="10">
                                <TextBlock Classes="section-title"
                                           Text="Изолируйте приложения, которым не доверяете" />
                                <TextBlock Classes="page-caption"
                                           Text="Agnosia помогает держать выбранные приложения отдельно от основного профиля телефона и управлять тем, когда они активны." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconWorkGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Изоляция в рабочем профиле" />
                                <TextBlock Classes="page-caption"
                                           Text="Переносите приложения в отдельный Android-профиль, чтобы их данные и окружение были отделены от личного профиля." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconCheckGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Контролируемый запуск" />
                                <TextBlock Classes="page-caption"
                                           Text="Открывайте изолированные приложения только когда они нужны. После использования Agnosia может снова их остановить." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconAppsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Меньше лишних следов" />
                                <TextBlock Classes="page-caption"
                                           Text="Настройки Agnosia помогают ограничивать фоновые действия приложений и скрывать нежелательные признаки вашего окружения." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconSettingsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Отключение VPN перед запуском" />
                                <TextBlock Classes="page-caption"
                                           Text="Agnosia может временно отключать VPN перед открытием рабочего приложения, чтобы оно не увидело адрес VPN-сервера." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconAlertGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Проверка опасности приложений" />
                                <TextBlock Classes="page-caption"
                                           Text="Agnosia анализирует разрешения приложений и показывает, какие из них могут собирать слишком много данных." />
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <StackPanel IsVisible="{Binding IsOnboardingWorkProfileStep}"
                            Spacing="16">
                    <Border Padding="8,10,8,8"
                            Background="Transparent">
                        <StackPanel MinWidth="0"
                                    Spacing="10">
                            <TextBlock Classes="section-title"
                                       Text="Создайте рабочий профиль Android" />
                            <TextBlock Classes="page-caption"
                                       Text="Agnosia откроет системную настройку Android. Завершите её, затем вернитесь в приложение." />
                        </StackPanel>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile permission-icon"
                                    Classes.granted="{Binding WorkProfileAvailable}">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconWorkGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="6">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Текущее состояние" />
                                <TextBlock Classes="page-caption"
                                           Text="{Binding WorkProfileStatusText, Converter={StaticResource LocalizationConverter}, ConverterParameter='String.Dashboard.WP.'}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconWorkGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Android создаст отдельное пространство" />
                                <TextBlock Classes="page-caption"
                                           Text="В нём будут свои приложения, настройки и данные." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconAppsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Agnosia станет администратором профиля" />
                                <TextBlock Classes="page-caption"
                                           Text="Android выдаст Agnosia права управления рабочим профилем и приложениями внутри него." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconCheckGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Вернитесь в Agnosia после настройки" />
                                <TextBlock Classes="page-caption"
                                           Text="Когда Android закончит создание профиля, откройте Agnosia снова. Мы проверим профиль и перейдём к разрешениям." />
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <StackPanel IsVisible="{Binding IsOnboardingPermissionsStep}"
                            Spacing="16">
                    <Border Padding="8,10,8,8"
                            Background="Transparent">
                        <StackPanel MinWidth="0"
                                    Spacing="10">
                            <TextBlock Classes="section-title"
                                       Text="Выдайте нужные разрешения" />
                            <TextBlock Classes="page-caption"
                                       Text="Без них Agnosia не сможет видеть приложения и управлять изоляцией. Откройте каждый пункт, который требует действия." />
                        </StackPanel>
                    </Border>

                    <views:PermissionListView Items="{Binding OnboardingPermissionItems}" />
                </StackPanel>

                <StackPanel IsVisible="{Binding IsOnboardingFinalStep}"
                            Spacing="16">
                    <Border Padding="8,10,8,8"
                            Background="Transparent">
                        <StackPanel MinWidth="0"
                                    Spacing="10">
                            <TextBlock Classes="section-title"
                                       Text="Отлично, Agnosia настроена" />
                            <TextBlock Classes="page-caption"
                                       Text="Рабочий профиль подключён, разрешения выданы, а инструменты изоляции готовы к работе." />
                        </StackPanel>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconAppsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Выберите приложение из личного профиля" />
                                <TextBlock Classes="page-caption"
                                           Text="Откройте карточку приложения и выберите Копировать в рабочий или Переместить в рабочий." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconLaunchGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Создавайте ярлыки для безопасного запуска" />
                                <TextBlock Classes="page-caption"
                                           Text="Ярлык временно откроет рабочее приложение. После использования Agnosia сможет снова его остановить." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="surface-card compact">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="icon-tile tutorial-step-icon">
                                <PathIcon Classes="section-icon centered"
                                          Data="{StaticResource IconSettingsGeometry}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        MinWidth="0"
                                        Spacing="5">
                                <TextBlock Classes="group-title feature-title"
                                           Text="Настройки можно изменить позже" />
                                <TextBlock Classes="page-caption"
                                           Text="VPN-сценарий, журнал событий и межпрофильный обмен доступны в настройках и карточках приложений." />
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource AppChromeBrush}"
                BorderBrush="{StaticResource AppBorderSoftBrush}"
                BorderThickness="0,1,0,0"
                Height="72">
            <Grid Margin="18,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        Classes="tag-chip dense"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsOnboardingPermissionsStep}">
                    <TextBlock Classes="tag-label"
                               Text="{Binding OnboardingPermissionSummary, Converter={StaticResource LocalizationConverter}, ConverterParameter='String.Permission.'}" />
                </Border>

                <Button Classes="primary"
                        Grid.Column="2"
                        Width="172"
                        Height="44"
                        MinHeight="44"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding IsOnboardingWelcomeStep}"
                        Command="{Binding StartOnboardingCommand}">
                    <TextBlock Classes="button-label"
                               TextAlignment="Center"
                               Text="Далее" />
                </Button>

                <Button Classes="primary"
                        Grid.Column="2"
                        Width="172"
                        Height="44"
                        MinHeight="44"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding IsOnboardingWorkProfileStep}"
                        Command="{Binding StartProvisioningCommand}"
                        IsEnabled="{Binding CanStartProvisioning}">
                    <TextBlock Classes="button-label"
                               TextAlignment="Center"
                               Text="Открыть настройки" />
                </Button>

                <Button Classes="primary"
                        Grid.Column="2"
                        Width="116"
                        Height="44"
                        MinHeight="44"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding IsOnboardingPermissionsStep}"
                        Command="{Binding FinishOnboardingCommand}">
                    <TextBlock Classes="button-label"
                               TextAlignment="Center"
                               Text="Далее" />
                </Button>

                <Button Classes="primary"
                        Grid.Column="2"
                        Width="116"
                        Height="44"
                        MinHeight="44"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding IsOnboardingFinalStep}"
                        Command="{Binding FinishOnboardingCommand}">
                    <TextBlock Classes="button-label"
                               TextAlignment="Center"
                               Text="Открыть приложения" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
